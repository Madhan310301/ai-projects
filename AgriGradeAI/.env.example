# AgriGradeAI Environment Variables
# Copy this file to .env and fill in your actual credentials.
# NEVER commit .env to version control.

# Google Gemini API key - get it from https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# MongoDB connection URI - get it from https://cloud.mongodb.com/
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/databasename